{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuantMechanica Strategy Archive Snapshot",
  "type": "object",
  "required": ["generated_at", "total", "items"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "source", "visibility", "last_updated_utc"],
        "properties": {
          "slug": { "type": "string" },
          "source": { "type": "string" },
          "visibility": {
            "type": "string",
            "enum": ["public", "private_redacted"]
          },
          "last_updated_utc": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
