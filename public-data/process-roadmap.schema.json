{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuantMechanica Process Roadmap Snapshot",
  "type": "object",
  "required": ["generated_at", "total", "items"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "last_updated_utc"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["active", "paused", "draft", "deprecated"]
          },
          "last_updated_utc": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
