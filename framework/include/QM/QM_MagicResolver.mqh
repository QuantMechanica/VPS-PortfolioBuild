00, 130680000, 130690000, 130700000, 130710000, 130710001, 130720000, 130730000, 130730001, 130740000, 130750000, 130760000, 130760001, 130770000, 130780000, 130790000, 130790001, 130800000, 130810000, 130820000, 130820001, 130830000, 130830001, 130840000, 130850000, 130850001, 130860000, 130860001, 130870000, 130870001, 130880000, 130890000, 130890001, 130900000, 130900001, 130910000, 130920000, 130920001, 130930000, 130930001, 130940000, 130940001, 130950000, 130960000, 130970000, 130980000, 130980001, 130990000, 131000000, 131010000, 131020000, 131030000, 131040000, 131050000, 131060000, 131060001, 131070000, 131080000, 131090000, 131100000, 131110000, 131120000, 131130000, 131130001, 131140000, 131150000, 131150001, 131160000, 131170000, 131170001, 131180000, 131180001, 131190000, 131190001, 131200000, 131200001, 131210000, 131210001, 131220000, 131230000, 131230001, 131260000, 131260001, 131280000, 131290000, 131290001, 131300000, 131300001, 131310000, 131310001, 131320000, 131320001, 131330000, 131330001, 131340000, 131370000, 131370001, 131370002, 131380000, 131390000, 131390001, 131400000, 131400001, 131410000, 131410001, 131420000, 131420001, 131430000, 131430001, 131440000, 131440001, 131450000, 131450001, 131460000, 131460001, 131470000, 131470001, 131480000, 131480001, 131490000, 131490001, 131500000, 131510000, 131510001, 132020000, 132030000, 132030001, 132040000, 132040001, 132040002, 132050000, 132050001, 132070000, 132090000, 132090001, 132100000, 132100001, 132120000, 132130000, 133010000, 133010001, 133010002, 133010003, 133010004, 133010005, 133010006, 133010007, 133010008, 133010009, 133010010, 200010000, 200020000, 200020001, 200040000, 200040001, 200050000, 200050001, 200050002, 200060000, 200070000, 200070001, 200070002, 200070003, 200080000, 200090000, 200090001, 200090002, 200090003, 200090004, 200090005, 200100000, 200110000, 200120000, 200120001, 200130000, 200140000, 200150000, 200160000, 200160001, 200170000, 200180000, 200190000, 20019