{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantmechanica.local/schemas/strategy-card-v2-execution-contract.json",
  "title": "QuantMechanica Strategy Card v2 execution contract registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "book_id", "contracts"],
  "properties": {
    "schema_version": {"const": 2},
    "book_id": {"type": "string", "minLength": 1},
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contract"}
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "symbol": ["timeframe"],
        "timeframe": ["symbol"],
        "variant_id": ["symbol", "timeframe"],
        "card_binding": ["symbol", "timeframe", "variant_id"],
        "runtime_binding": ["symbol", "timeframe", "variant_id", "card_binding"],
        "data_dependencies": ["card_binding", "runtime_binding"],
        "symbol_routing": ["symbol", "timeframe"]
      },
      "required": [
        "ea_id",
        "slug",
        "card_ref",
        "source",
        "strategy_timeframe",
        "bar_gate_timeframe",
        "friday_close",
        "calendar",
        "promotion"
      ],
      "properties": {
        "ea_id": {"type": "integer", "minimum": 1},
        "symbol": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]{1,15}\\.DWX$"
        },
        "timeframe": {"$ref": "#/$defs/timeframe"},
        "variant_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
        },
        "slug": {"type": "string", "minLength": 1},
        "card_ref": {"type": "string", "minLength": 1},
        "source": {"type": "string", "pattern": "\\.mq5$"},
        "strategy_timeframe": {"$ref": "#/$defs/timeframe"},
        "bar_gate_timeframe": {"$ref": "#/$defs/timeframe"},
        "darwinex_zero_routing": {"$ref": "#/$defs/symbolRouting"},
        "symbol_routing": {"$ref": "#/$defs/symbolRouting"},
        "card_binding": {"$ref": "#/$defs/cardBinding"},
        "runtime_binding": {"$ref": "#/$defs/runtimeBinding"},
        "data_dependencies": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/dataDependency"}
        },
        "friday_close": {"$ref": "#/$defs/fridayClose"},
        "calendar": {"$ref": "#/$defs/calendar"},
        "promotion": {"$ref": "#/$defs/promotion"}
      },
      "allOf": [
        {
          "not": {
            "required": ["darwinex_zero_routing", "symbol_routing"]
          }
        }
      ]
    },
    "symbolRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_symbol",
        "live_order_symbol",
        "status",
        "source_registry",
        "evidence_ref",
        "automatic_symbol_inference",
        "qualification_status",
        "full_requalification_required"
      ],
      "properties": {
        "test_symbol": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]{1,15}\\.DWX$"
        },
        "live_order_symbol": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9._-]{1,31}$",
          "not": {"pattern": "\\.DWX$"}
        },
        "status": {"const": "BACKTEST_ALIAS_TO_ORDER_ROUTABLE_BROKER_SYMBOL"},
        "source_registry": {"type": "string", "minLength": 1},
        "evidence_ref": {"type": "string", "minLength": 1},
        "automatic_symbol_inference": {"const": false},
        "qualification_status": {"enum": ["PASS", "REQUAL_REQUIRED", "BLOCKED"]},
        "full_requalification_required": {"const": true}
      }
    },
    "cardBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ea_id",
        "slug",
        "timeframe",
        "variant_id",
        "status",
        "execution_contract_status"
      ],
      "properties": {
        "ea_id": {"type": "integer", "minimum": 1},
        "slug": {"type": "string", "minLength": 1},
        "timeframe": {"$ref": "#/$defs/timeframe"},
        "variant_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
        },
        "status": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,31}$"
        },
        "execution_contract_status": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,31}$"
        }
      }
    },
    "runtimeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qm_ea_id", "magic_slot_offset", "setfile", "setfile_sha256"],
      "properties": {
        "qm_ea_id": {"type": "integer", "minimum": 1},
        "magic_slot_offset": {"type": "integer", "minimum": 0},
        "setfile": {"type": "string", "pattern": "\\.set$"},
        "setfile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "magic_registry": {"type": "string", "minLength": 1}
      }
    },
    "dependencyCommon": {
      "type": "object",
      "required": [
        "dependency_id",
        "type",
        "qualification_status",
        "required_for",
        "block_reason"
      ],
      "properties": {
        "dependency_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        },
        "type": {
          "enum": ["calendar", "artifact", "signal_anchor", "session_metadata"]
        },
        "qualification_status": {
          "enum": ["PASS", "REQUAL_REQUIRED", "BLOCKED"]
        },
        "required_for": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["ENTRY", "EXIT", "SIZING", "SIGNAL_ONLY", "PROMOTION"]
          }
        },
        "block_reason": {"type": ["string", "null"]}
      }
    },
    "dependencyQualification": {
      "allOf": [
        {
          "if": {
            "properties": {"qualification_status": {"const": "PASS"}},
            "required": ["qualification_status"]
          },
          "then": {"properties": {"block_reason": {"type": "null"}}},
          "else": {
            "properties": {
              "block_reason": {"type": "string", "minLength": 1}
            }
          }
        }
      ]
    },
    "dataDependency": {
      "oneOf": [
        {"$ref": "#/$defs/calendarDependency"},
        {"$ref": "#/$defs/artifactDependency"},
        {"$ref": "#/$defs/signalAnchorDependency"},
        {"$ref": "#/$defs/sessionMetadataDependency"}
      ]
    },
    "calendarDependency": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "coverage_start": ["coverage_end"],
        "coverage_end": ["coverage_start"]
      },
      "required": [
        "dependency_id",
        "type",
        "qualification_status",
        "required_for",
        "block_reason",
        "source_ref",
        "calendar_policy",
        "stale_behavior"
      ],
      "properties": {
        "dependency_id": {"$ref": "#/$defs/dependencyCommon/properties/dependency_id"},
        "type": {"const": "calendar"},
        "qualification_status": {"$ref": "#/$defs/dependencyCommon/properties/qualification_status"},
        "required_for": {"$ref": "#/$defs/dependencyCommon/properties/required_for"},
        "block_reason": {"$ref": "#/$defs/dependencyCommon/properties/block_reason"},
        "source_ref": {"type": "string", "minLength": 1},
        "calendar_policy": {"type": "string", "minLength": 1},
        "stale_behavior": {"enum": ["NOT_APPLICABLE", "INIT_AND_ENTRY_FAIL_CLOSED", "ENTRY_FAIL_CLOSED"]},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "coverage_start": {"type": "string", "format": "date"},
        "coverage_end": {"type": "string", "format": "date"}
      },
      "allOf": [{"$ref": "#/$defs/dependencyQualification"}]
    },
    "artifactDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_id",
        "type",
        "qualification_status",
        "required_for",
        "block_reason",
        "path",
        "sha256"
      ],
      "properties": {
        "dependency_id": {"$ref": "#/$defs/dependencyCommon/properties/dependency_id"},
        "type": {"const": "artifact"},
        "qualification_status": {"$ref": "#/$defs/dependencyCommon/properties/qualification_status"},
        "required_for": {"$ref": "#/$defs/dependencyCommon/properties/required_for"},
        "block_reason": {"$ref": "#/$defs/dependencyCommon/properties/block_reason"},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      },
      "allOf": [
        {"$ref": "#/$defs/dependencyQualification"},
        {
          "if": {
            "properties": {"qualification_status": {"const": "PASS"}},
            "required": ["qualification_status"]
          },
          "then": {
            "properties": {
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      ]
    },
    "signalAnchorDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependency_id",
        "type",
        "qualification_status",
        "required_for",
        "block_reason",
        "symbol",
        "timeframe",
        "order_allowed"
      ],
      "properties": {
        "dependency_id": {"$ref": "#/$defs/dependencyCommon/properties/dependency_id"},
        "type": {"const": "signal_anchor"},
        "qualification_status": {"$ref": "#/$defs/dependencyCommon/properties/qualification_status"},
        "required_for": {"$ref": "#/$defs/dependencyCommon/properties/required_for"},
        "block_reason": {"$ref": "#/$defs/dependencyCommon/properties/block_reason"},
        "symbol": {"type": "string", "pattern": "^[A-Z][A-Z0-9]{1,15}\\.DWX$"},
        "timeframe": {"$ref": "#/$defs/timeframe"},
        "order_allowed": {"const": false},
        "source_ref": {"type": "string", "minLength": 1}
      },
      "allOf": [{"$ref": "#/$defs/dependencyQualification"}]
    },
    "sessionMetadataDependency": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "coverage_start": ["coverage_end"],
        "coverage_end": ["coverage_start"]
      },
      "required": [
        "dependency_id",
        "type",
        "qualification_status",
        "required_for",
        "block_reason",
        "metadata_kind",
        "source_ref"
      ],
      "properties": {
        "dependency_id": {"$ref": "#/$defs/dependencyCommon/properties/dependency_id"},
        "type": {"const": "session_metadata"},
        "qualification_status": {"$ref": "#/$defs/dependencyCommon/properties/qualification_status"},
        "required_for": {"$ref": "#/$defs/dependencyCommon/properties/required_for"},
        "block_reason": {"$ref": "#/$defs/dependencyCommon/properties/block_reason"},
        "metadata_kind": {
          "enum": ["BROKER_SESSION", "BROKER_BREAKS", "ROLLOVER", "FINANCING", "SESSION_EXCEPTION_CALENDAR"]
        },
        "source_ref": {"type": "string", "minLength": 1},
        "coverage_start": {"type": "string", "format": "date"},
        "coverage_end": {"type": "string", "format": "date"}
      },
      "allOf": [{"$ref": "#/$defs/dependencyQualification"}]
    },
    "timeframe": {
      "enum": ["M1", "M5", "M15", "M30", "H1", "H4", "D1", "W1", "MN1"]
    },
    "fridayClose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "hour_broker", "mode", "declaration", "qualification_status"],
      "properties": {
        "enabled": {"type": "boolean"},
        "hour_broker": {"type": ["integer", "null"], "minimum": 0, "maximum": 23},
        "mode": {"enum": ["DISABLED", "CARD_RULE", "FRAMEWORK_OVERRIDE"]},
        "declaration": {"type": "string"},
        "qualification_status": {"enum": ["PASS", "REQUAL_REQUIRED", "BLOCKED"]},
        "card_evidence": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"mode": {"const": "DISABLED"}}},
          "then": {"properties": {"enabled": {"const": false}, "hour_broker": {"type": "null"}}}
        },
        {
          "if": {"properties": {"mode": {"enum": ["CARD_RULE", "FRAMEWORK_OVERRIDE"]}}},
          "then": {"properties": {"enabled": {"const": true}, "hour_broker": {"type": "integer"}}}
        },
        {
          "if": {"properties": {"mode": {"const": "CARD_RULE"}}},
          "then": {"required": ["card_evidence"]}
        }
      ]
    },
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy"],
      "properties": {
        "policy": {
          "enum": [
            "NONE",
            "FIXED_EVENT_TABLE",
            "FTMO_PRE30_POST30_NEWS_FILES_FAIL_CLOSED"
          ]
        },
        "valid_through": {"type": "string", "format": "date"},
        "source": {"type": "string"},
        "stale_behavior": {"enum": ["NOT_APPLICABLE", "INIT_AND_ENTRY_FAIL_CLOSED"]},
        "temporal_mode": {"enum": ["PRE30_POST30"]},
        "compliance_profile": {"enum": ["FTMO"]},
        "minimum_impact": {"enum": ["high"]},
        "stale_max_hours": {"const": 336},
        "live_source": {"enum": ["NATIVE_MT5_CALENDAR"]},
        "sources": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/calendarSource"},
          "allOf": [
            {
              "contains": {
                "properties": {"role": {"const": "SHARED_PRIMARY"}},
                "required": ["role"]
              }
            },
            {
              "contains": {
                "properties": {"role": {"const": "SHARED_SECONDARY"}},
                "required": ["role"]
              }
            },
            {
              "contains": {
                "properties": {"role": {"const": "QMDEV1_COMMON_PRIMARY"}},
                "required": ["role"]
              }
            },
            {
              "contains": {
                "properties": {"role": {"const": "QMDEV1_COMMON_SECONDARY"}},
                "required": ["role"]
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"policy": {"const": "FIXED_EVENT_TABLE"}}},
          "then": {"required": ["valid_through", "source", "stale_behavior"]}
        },
        {
          "if": {
            "properties": {
              "policy": {"const": "FTMO_PRE30_POST30_NEWS_FILES_FAIL_CLOSED"}
            }
          },
          "then": {
            "required": [
              "temporal_mode",
              "compliance_profile",
              "minimum_impact",
              "stale_max_hours",
              "stale_behavior",
              "live_source",
              "sources"
            ],
            "properties": {
              "stale_behavior": {"const": "INIT_AND_ENTRY_FAIL_CLOSED"}
            }
          }
        }
      ]
    },
    "calendarSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "sha256", "coverage_start", "coverage_end"],
      "properties": {
        "role": {
          "enum": [
            "SHARED_PRIMARY",
            "SHARED_SECONDARY",
            "QMDEV1_COMMON_PRIMARY",
            "QMDEV1_COMMON_SECONDARY"
          ]
        },
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "coverage_start": {"type": "string", "format": "date"},
        "coverage_end": {"type": "string", "format": "date"}
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "block_reasons"],
      "properties": {
        "status": {"enum": ["ELIGIBLE", "REQUAL_REQUIRED", "BLOCKED"]},
        "block_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
